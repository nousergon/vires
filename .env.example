# Copy to .env for local overrides. All keys are prefixed VIRES_.
# VIRES_DATABASE_URL=sqlite:///./vires.db
# VIRES_FASTEMBED_CACHE_DIR=.fastembed_cache
# VIRES_DEV_TENANT_ID=dev-tenant
# VIRES_DEV_USER_ID=dev-user

# AI coach (optional). Without a key the coach 503s and the rest of the app works.
# In prod the key is hydrated from SSM by deploy-on-merge.sh — set it here only
# for local coach testing. NEVER commit a real key.
# VIRES_ANTHROPIC_API_KEY=sk-ant-...
# VIRES_COACH_MODEL=claude-haiku-4-5   # bump to claude-sonnet-4-6 for stronger plans
# Tuned coach prompt is the private edge: in prod it's hydrated from SSM to the
# gitignored prompts/coach_system.txt; absent => the committed .example baseline.
# VIRES_COACH_PROMPT_PATH=/path/to/coach_system.txt   # explicit override (rarely needed)
# Speech-to-text (optional). OpenAI-compatible Whisper; absent => mic hidden + 503.
# VIRES_STT_API_KEY=sk-...
# VIRES_STT_MODEL=whisper-1                      # or e.g. whisper-large-v3-turbo on Groq
# VIRES_STT_BASE_URL=https://api.openai.com/v1  # point at Groq for cheaper/faster STT
# Web Push (optional) — locked-screen timer alerts. Generate: python scripts/gen_vapid.py
# VIRES_VAPID_PUBLIC_KEY=...    # applicationServerKey (non-secret)
# VIRES_VAPID_PRIVATE_KEY=...   # SECRET — raw base64url private key
# VIRES_VAPID_SUBJECT=mailto:brian@nousergon.ai
