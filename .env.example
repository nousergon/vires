# Copy to .env for local overrides. All keys are prefixed VIRES_.
# VIRES_DATABASE_URL=sqlite:///./vires.db
# VIRES_FASTEMBED_CACHE_DIR=.fastembed_cache
# VIRES_DEV_TENANT_ID=dev-tenant
# VIRES_DEV_USER_ID=dev-user

# AI coach (optional). Without a key the coach 503s and the rest of the app works.
# In prod the key is hydrated from SSM by deploy-on-merge.sh — set it here only
# for local coach testing. NEVER commit a real key.
# VIRES_ANTHROPIC_API_KEY=sk-ant-...
# VIRES_COACH_MODEL=claude-haiku-4-5   # bump to claude-sonnet-4-6 for stronger plans
